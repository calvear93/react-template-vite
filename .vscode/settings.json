{
    "[css]": {
        "editor.defaultFormatter": "svipas.prettier-plus"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[scss]": {
        "editor.defaultFormatter": "svipas.prettier-plus"
    },
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "css.lint.unknownAtRules": "ignore",
    "editor.detectIndentation": true,
    "editor.rulers": [80, 100],
    "eslint.format.enable": true,
    "eslint.lintTask.enable": true,
    "eslint.probe": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "json"
    ],
    "eslint.trace.server": "off",
    "eslint.useESLintClass": true,
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.env.json": "${capture}.*.env.json",
		"*.json": "${capture}.json",
		"*.ts": "${capture}.*",
		"*.tsx": "${capture}.*",
		".eslintrc.json": ".eslintignore",
		"README*": "CHANGELOG*, LICENSE*",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, pnpm-workspace.yaml, package.release.json",
		"tsconfig.json": "tsconfig.*.json",
		"vite.config.ts": "vitest.config.ts, windi.config.ts"
    },
    "explorer.incrementalNaming": "smart",
    "explorer.sortOrder": "type",
    "files.exclude": {
        "**/*.log": true,
		"**/*.tsbuildinfo": true,
		"**/.DS_Store": true,
		"**/.git": true,
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg": true,
		"**/.history/**": true,
		"**/.svn": true,
		"**/CVS": true,
		"**/bower_components/**": true,
		"**/desktop.ini": true,
		"**/folderico*.ico": true,
		"**/node_modules/**": true
    },
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "prettier.eslintIntegration": true,
    "prettier.stylelintIntegration": true,
    "prettier.useTabs": true,
    "scss.lint.unknownAtRules": "ignore",
    "stylelint.snippet": ["css", "less", "postcss", "scss", "sass"],
    "stylelint.validate": ["css", "less", "postcss", "sass", "scss"],
    "typescript.tsdk": "node_modules\\typescript\\lib"
}
